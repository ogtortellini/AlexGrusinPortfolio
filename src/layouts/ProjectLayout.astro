---
import BaseLayout from './BaseLayout.astro';

interface TocItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

interface Props {
  title: string;
  subtitle?: string;
  toc: TocItem[];
}

const { title, subtitle, toc } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout title={`${title} | Alex Grusin`}>
  <!-- Nav -->
  <nav class="bg-white dark:bg-gray-800 shadow p-4 sticky top-0 z-50 flex justify-between items-center">
    <a href={`${base}`} class="text-blue-600 dark:text-blue-400 hover:underline text-sm font-medium">
      &larr; Back to Home
    </a>
    <!-- Mobile TOC toggle -->
    <div class="relative lg:hidden">
      <button
        id="tocToggleButton"
        class="text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 focus:outline-none p-1"
        aria-label="Toggle table of contents"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
      <div
        id="tocDropdownMenu"
        class="hidden absolute right-0 mt-2 w-72 bg-white dark:bg-gray-800 rounded-lg shadow-lg z-[60] py-2"
      >
        <p class="text-sm font-semibold px-4 py-2 text-gray-500 dark:text-gray-400 uppercase tracking-wider font-mono">Contents</p>
        <ul class="text-sm">
          {toc.map((item) => (
            <li>
              <a
                href={item.href}
                class="toc-link-dropdown block px-4 py-2 text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700"
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="ml-4">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="toc-link-dropdown block px-4 py-2 text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 flex flex-col lg:flex-row gap-8">
    <!-- Desktop sidebar TOC -->
    <aside class="hidden lg:block w-1/4 flex-shrink-0 self-start sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto">
      <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow">
        <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider font-mono mb-4">Contents</p>
        <ul class="space-y-1 text-sm">
          {toc.map((item) => (
            <li>
              <a
                href={item.href}
                class="toc-link block py-1 text-gray-700 dark:text-gray-200 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              >
                {item.label}
              </a>
              {item.children && (
                <ul class="ml-3 mt-1 space-y-1">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="toc-link block py-1 text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors text-xs"
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 min-w-0 bg-white dark:bg-gray-800 p-8 rounded-xl shadow">
      <h1 class="text-4xl font-bold mb-3 text-center dark:text-gray-100">{title}</h1>
      {subtitle && (
        <p class="text-center text-gray-500 dark:text-gray-400 mb-10 text-lg">{subtitle}</p>
      )}
      <slot />
    </main>
  </div>

  <footer class="text-center py-8 mt-4 border-t border-gray-200 dark:border-gray-700">
    <p class="text-sm text-gray-500 dark:text-gray-400 font-mono">&copy; 2025 Alex Grusin</p>
  </footer>
</BaseLayout>

<script>
  // Mobile TOC toggle
  const toggleBtn = document.getElementById('tocToggleButton');
  const dropdownMenu = document.getElementById('tocDropdownMenu');

  if (toggleBtn && dropdownMenu) {
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownMenu.classList.toggle('hidden');
    });
    document.addEventListener('click', (e) => {
      if (!dropdownMenu.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
        dropdownMenu.classList.add('hidden');
      }
    });
  }

  // TOC scroll highlighting
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link, .toc-link-dropdown');
  const sections = document.querySelectorAll<HTMLElement>('section[id], article[id]');

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach((link) => {
            const active = link.getAttribute('href') === `#${id}`;
            link.classList.toggle('active', active);
          });
        }
      }
    },
    { rootMargin: '-15% 0% -65% 0%', threshold: 0 }
  );

  sections.forEach((s) => observer.observe(s));
</script>
