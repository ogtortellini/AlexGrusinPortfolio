---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Contact | Alex Grusin">
  <nav class="bg-white dark:bg-gray-800 shadow p-4">
    <a href={`${base}`} class="text-blue-600 dark:text-blue-400 hover:underline text-sm font-medium">
      &larr; Back to Home
    </a>
  </nav>

  <main class="max-w-2xl mx-auto px-6 py-14">
    <h1 class="text-3xl font-bold mb-2 dark:text-gray-100">Contact</h1>
    <p class="text-gray-500 dark:text-gray-400 font-mono text-sm mb-8">Get in touch</p>

    <form
      action="https://formspree.io/f/xnndlkkj"
      method="POST"
      class="bg-white dark:bg-gray-800 p-8 rounded-xl shadow space-y-5"
    >
      <div>
        <label for="name" class="block text-sm font-medium mb-1 dark:text-gray-200">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1 dark:text-gray-200">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1 dark:text-gray-200">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 font-semibold transition-colors"
      >
        Send Message
      </button>
    </form>
  </main>

  <footer class="text-center py-8 mt-8 border-t border-gray-200 dark:border-gray-700">
    <p class="text-sm text-gray-500 dark:text-gray-400 font-mono">&copy; 2025 Alex Grusin</p>
  </footer>
</BaseLayout>
